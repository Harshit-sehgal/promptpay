NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgresql://waitlayer:waitlayer@localhost:5432/waitlayer?schema=public

REDIS_URL=redis://localhost:6379

API_PORT=4000
API_BASE_URL=http://localhost:4000

WEB_PORT=3000
WEB_BASE_URL=http://localhost:3000

JWT_SECRET=replace-with-random-32-char-secret-for-jwt-signing
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Extension HMAC secret for request signature verification
EXTENSION_HMAC_SECRET=replace-with-random-32-char-secret-for-hmac

# Transactional email
# EMAIL_DRIVER: console (default, logs only) | resend (requires RESEND_API_KEY)
EMAIL_DRIVER=console
EMAIL_FROM="WaitLayer <no-reply@waitlayer.dev>"
RESEND_API_KEY=

# Stripe (optional in MVP)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal (optional in MVP)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
