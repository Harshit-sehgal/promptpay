# ══════════════════════════════════════════════════════════
# WaitLayer — Environment Variables Example
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.

# ── General ──
NODE_ENV=development
LOG_LEVEL=info

# ── Database ──
DATABASE_URL=postgresql://waitlayer:waitlayer-dev@localhost:5432/waitlayer

# ── Redis (required in production for distributed rate limiting) ──
# Local development can omit this and use in-memory counters.
# REDIS_URL=redis://localhost:6379

# ── API ──
API_PORT=4002
API_BASE_URL=http://localhost:4002

# ── Web ──
WEB_PORT=3000
WEB_BASE_URL=http://localhost:3000

# ── Auth ──
# JWT access/refresh tokens are signed with RS256. Provide a PEM-encoded
# RSA key pair. JWT_SECRET is still required for refresh-token HMAC and
# BFF rate-limit identity signing.
# Generate a 2048-bit RSA key pair with:
#   openssl genrsa -out jwt-private.pem 2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
#
# ⚠️  The PEM blocks below are placeholders. Replace them with the real
# contents of your generated jwt-private.pem / jwt-public.pem files.
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC8Z5F5q3v3T8vH\n...\nJWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA8Z5F5q3v3T8vH\n...
# Optional: zero-downtime RS256 key rotation. During a key rollover, set
# JWT_PRIVATE_KEY/JWT_PUBLIC_KEY to the NEW pair and list the PREVIOUS public
# key here (newline-separated) so pre-rotation access and refresh tokens keep
# verifying. Supply the same JWT_PUBLIC_KEY(S), JWT_ISSUER, and JWT_AUDIENCE to
# the web build. Keep the old key for at least JWT_REFRESH_TTL before dropping it.
# Format: newline-separated PEM PUBLIC KEY blocks (literal "\n" escapes ok).
# JWT_PUBLIC_KEYS=-----BEGIN PUBLIC KEY-----\nMIIBIjAN...\n-----END PUBLIC KEY-----\n-----BEGIN PUBLIC KEY-----\nMIIBIjAN...\n-----END PUBLIC KEY-----
# JWT_SECRET must be >= 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=local-dev-jwt-secret-at-least-32-char
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# JWT_ISSUER=waitlayer
# JWT_AUDIENCE=waitlayer-client
# Required in production for encrypting server-stored TOTP/MFA secrets.
# Generate with: openssl rand -base64 48
# TOTP_SECRET_ENCRYPTION_KEY=replace-with-openssl-rand-base64-48
# Maximum age of an admin MFA step-up token (default 900 seconds).
# ADMIN_MFA_STEP_UP_MAX_AGE_SECONDS=900

# ── Extension / wait-detection trust ──
# Comma-separated allowlist of verified detector versions. Missing/empty means
# every detector source is unverified (fail-closed) and earnings are held longer.
# VERIFIED_DETECTOR_VERSIONS=1.0.0,1.1.0
# JSON array: [{"provider":"example","issuer":"https://attestor.example","audience":"waitlayer","publicKeys":{"kid":"-----BEGIN PUBLIC KEY-----\\n..."}}]
# WAIT_ATTESTATION_ISSUERS=
# VERIFIED_WAIT_ATTESTATION_VERSIONS=provider-v1

# ── Extension signing ──
# Event payloads are signed with server-issued per-device eventSecret values.
# There is no shared global extension HMAC secret.

# ── Stripe (advertiser deposits — optional for dev) ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Google OAuth (optional for dev, required for production) ──
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Mock Google (dev only — NEVER enable in staging/production) ──
# When BOTH NODE_ENV !== 'production' AND one of these flags is set,
# the verifier accepts `mock-google-token-<name>` tokens to skip
# real Google OAuth during local development. These flags are
# intentionally off-by-default to prevent staging/preview drift.
# ALLOW_MOCK_GOOGLE=true
# MOCK_GOOGLE_ENABLED=1

# ── Web (Next.js front-end) ──
# NEXT_PUBLIC_API_URL=http://localhost:4002/api/v1
# API_INTERNAL_URL=http://localhost:4002/api/v1
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# NEXT_PUBLIC_ALLOW_MOCK_AUTH=true   # dev-only — shows mock button in login page
# BFF_TRUST_PROXY_HOPS=1

# ── Email ──
# EMAIL_DRIVER=console     # console (default, logs to stdout) or resend
# EMAIL_FROM=noreply@waitlayer.local
# OPS_ALERT_EMAIL=ops@waitlayer.com  # operator inbox for money-integrity + security alerts (prod: required)
# RESEND_API_KEY=re_...     # Required if EMAIL_DRIVER=resend
# EMAIL_QUEUE_SECRET=generated-32-plus-character-secret  # prod: required
# EMAIL_PROVIDER_TIMEOUT_MS=10000

# ── Privacy pseudonymization (required in production) ──
# PRIVACY_HASH_KEY=generated-32-plus-character-secret

# ── Sentry (error monitoring — optional for dev) ──
# Create a project at https://sentry.io and get your DSN.
# SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/654321
# SENTRY_ENVIRONMENT=development
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-auth-token   # Required for source map uploads in CI

# ── PayPal (payouts — optional for dev) ──
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
# PAYPAL_MODE=sandbox

# ── Wise (payouts — optional for dev) ──
# Requires a Wise business profile. The profile funds developer payouts.
# WISE_API_TOKEN=...
# WISE_PROFILE_ID=...
# WISE_MODE=sandbox   # set to 'live' only with token + profile id set
# WISE_EMAIL_RECIPIENTS_VERIFIED=false

# ── Payout security ──
# Require MFA (TOTP) before any payout can be requested (default off).
# PAYOUT_REQUIRE_2FA=false
# Anti-account-takeover: require MFA for payouts to a destination changed
# within this many hours (default 0 = off). Set e.g. 24 to block a stolen
# session from repointing payouts to a fresh destination.
# PAYOUT_DESTINATION_COOLDOWN_HOURS=0
# WAITLAYER_PAYOUT_PROVIDER_STATUS={"manual":"available","wise":"coming_soon"}

# ── Feature toggles (opt-in; OFF by default) ──
# Reclaim orphaned Stripe webhook events. Production may not disable this.
# WEBHOOK_RECLAIM_CRON=true
# Apply the 80/10/10 launch earnings split (dev/platform/reserve).
# LAUNCH_SPLIT_ENABLED=false
# Legacy compatibility flag; only false is accepted.
# WEBHOOK_ASYNC_PROCESSING=false
# SWAGGER_ENABLED=false

# ── Reverse proxy (CORS / per-IP rate limiting) ──
# Number of trusted proxy hops in front of the API (default 1; max 3).
# TRUST_PROXY_HOPS=1
