# ══════════════════════════════════════════════════════════
# WaitLayer — Environment Variables Example
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.

# ── General ──
NODE_ENV=development
LOG_LEVEL=info

# ── Database ──
DATABASE_URL=postgresql://waitlayer:waitlayer-dev@localhost:5432/waitlayer

# ── Redis (required in production for distributed rate limiting) ──
# Local development can omit this and use in-memory counters.
# REDIS_URL=redis://localhost:6379

# ── API ──
API_PORT=4002
API_BASE_URL=http://localhost:4002

# ── Web ──
WEB_PORT=3000
WEB_BASE_URL=http://localhost:3000

# ── Auth (REQUIRED: JWT_SECRET must be >= 32 chars) ──
# Generate with: openssl rand -base64 48
JWT_SECRET=local-dev-jwt-secret-at-least-32-char
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Required in production for encrypting server-stored TOTP/MFA secrets.
# Generate with: openssl rand -base64 48
# TOTP_SECRET_ENCRYPTION_KEY=replace-with-openssl-rand-base64-48

# ── Extension signing ──
# Event payloads are signed with server-issued per-device eventSecret values.
# There is no shared global extension HMAC secret.

# ── Stripe (advertiser deposits — optional for dev) ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Google OAuth (optional for dev, required for production) ──
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Mock Google (dev only — NEVER enable in staging/production) ──
# When BOTH NODE_ENV !== 'production' AND one of these flags is set,
# the verifier accepts `mock-google-token-<name>` tokens to skip
# real Google OAuth during local development. These flags are
# intentionally off-by-default to prevent staging/preview drift.
# ALLOW_MOCK_GOOGLE=true
# MOCK_GOOGLE_ENABLED=1

# ── Web (Next.js front-end) ──
# NEXT_PUBLIC_API_URL=http://localhost:4002/api/v1
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# NEXT_PUBLIC_ALLOW_MOCK_AUTH=true   # dev-only — shows mock button in login page

# ── Email ──
# EMAIL_DRIVER=console     # console (default, logs to stdout) or resend
# EMAIL_FROM=noreply@waitlayer.local
# RESEND_API_KEY=re_...     # Required if EMAIL_DRIVER=resend

# ── Sentry (error monitoring — optional for dev) ──
# Create a project at https://sentry.io and get your DSN.
# SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/654321
# SENTRY_ENVIRONMENT=development
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-auth-token   # Required for source map uploads in CI

# ── PayPal (payouts — optional for dev) ──
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
# PAYPAL_MODE=sandbox

# ── Wise (payouts — optional for dev) ──
# Requires a Wise business profile. The profile funds developer payouts.
# WISE_API_TOKEN=...
# WISE_PROFILE_ID=...
# WISE_MODE=sandbox   # set to 'live' only with token + profile id set

# ── Payout security ──
# Require MFA (TOTP) before any payout can be requested (default off).
# PAYOUT_REQUIRE_2FA=false
# Anti-account-takeover: require MFA for payouts to a destination changed
# within this many hours (default 0 = off). Set e.g. 24 to block a stolen
# session from repointing payouts to a fresh destination.
# PAYOUT_DESTINATION_COOLDOWN_HOURS=0

# ── Feature toggles (opt-in; OFF by default) ──
# Reclaim orphaned Stripe webhook events (enable only in multi-instance /
# high-durability deployments; single-instance is safe off).
# WEBHOOK_RECLAIM_CRON=false
# Apply the 80/10/10 launch earnings split (dev/platform/reserve).
# LAUNCH_SPLIT_ENABLED=false
# Process Stripe webhooks off the request thread via the event bus.
# WEBHOOK_ASYNC_PROCESSING=false

# ── Reverse proxy (CORS / per-IP rate limiting) ──
# Number of trusted proxy hops in front of the API (default 1; max 3).
# TRUST_PROXY_HOPS=1
