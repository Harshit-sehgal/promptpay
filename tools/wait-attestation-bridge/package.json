{
  "name": "@waitlayer/wait-attestation-bridge",
  "version": "0.0.1",
  "private": true,
  "description": "Reference/stub independent wait-attestation provider bridge for local and staging development.",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
