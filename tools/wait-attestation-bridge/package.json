    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "jose": "^6.2.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@waitlayer/eslint-config": "workspace:*",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "vitest": "4.1.10"
  }
