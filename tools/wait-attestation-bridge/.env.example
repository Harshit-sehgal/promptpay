# Wait-attestation bridge (reference/stub)
# Copy to .env and fill in real values for non-local use.

PORT=4003
ATTESTATION_PROVIDER=waitlayer-stub-bridge
ISSUER=https://waitlayer.local/attestation
AUDIENCE=waitlayer-client
ATTESTATION_VERSION=stub-v1

# Bearer token clients must send in the Authorization header.
# In production, read this from a secret manager (e.g. via BRIDGE_TOKEN_PATH).
BRIDGE_TOKEN=change-me-in-production

# Where to persist the generated RSA key pair.
PRIVATE_KEY_PATH=.keys/bridge-private.pem
PUBLIC_KEY_PATH=.keys/bridge-public.pem

# Set to false to fail startup when keys are missing instead of generating them.
GENERATE_KEY_PAIR=true
