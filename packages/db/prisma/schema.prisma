generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ══════════════════════════════════════════════════════════
// Enums
// ══════════════════════════════════════════════════════════

enum UserRole {
  developer
  advertiser
  admin
  support
  super_admin
}

enum UserStatus {
  active
  restricted
  banned
  deleted
}

enum ReferralStatus {
  pending
  rewarded
}

enum TrustLevel {
  new
  low_trust
  normal
  high_trust
  restricted
  banned
}

enum CampaignStatus {
  draft
  submitted
  approved
  active
  paused
  rejected
  archived
}

enum CreativeStatus {
  draft
  pending_review
  approved
  rejected
  paused
}

enum BidType {
  cpm
  cpc
}

enum EventType {
  wait_state_start
  wait_state_end
  ad_request
  ad_rendered
  qualified_impression
  click
  report_ad
}

enum ToolTypeEnum {
  vscode
  cursor
  cline
  windsurf
  aider
  codex_cli
  claude_code
  terminal
  browser
}

enum LedgerEntryType {
  debit
  credit
  hold
  release
  reversal
  payout
  refund
  reserve
  fee
}

enum LedgerStatus {
  estimated
  pending
  confirmed
  held
  reversed
  paid
  void
}

enum PayoutProvider {
  manual
  paypal_email
  paypal_payouts
  stripe_connect
  payoneer
  wise
  razorpay
}

enum PayoutStatus {
  draft
  requested
  under_review
  approved
  rejected
  processing
  paid
  failed
  cancelled
}

enum FraudFlagStatus {
  open
  reviewing
  resolved_valid
  resolved_invalid
  escalated
}

enum FraudFlagType {
  impression_rate_limit
  click_rate_limit
  duplicate_device
  suspicious_ctr
  impossible_volume
  shared_payout_destination
  vpn_proxy_pattern
  emulator_vm_pattern
  rapid_earning_spike
  country_device_change
  repeated_click_abuse
  self_clicking
  automated_pattern
  duplicate_account
}

enum FraudSeverity {
  low
  medium
  high
  critical
}

enum ApprovalDecision {
  approved
  rejected
  changes_requested
}

enum RecoveryDebtCaseStatus {
  open
  in_collections
  recovered
  written_off
  closed
}

// ══════════════════════════════════════════════════════════
// User & Identity
// ══════════════════════════════════════════════════════════

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  passwordHash   String?
  name           String?
  role           UserRole   @default(developer)
  status         UserStatus @default(active)
  trustLevel     TrustLevel @default(new)
  country        String?
  googleId       String?    @unique
  githubId       String?
  emailVerified  Boolean    @default(false)
  googleVerified Boolean    @default(false)
  githubVerified Boolean    @default(false)
  referralCode   String?    @unique

  // ── Multi-factor authentication (TOTP) ──
  // `twoFactorSecret` stores the base32 TOTP secret. Enrollment is a two-step
  // flow (setup returns a provisioning secret; enable verifies a code and flips
  // `twoFactorEnabled`). Rotation requires disabling with a current code before
  // setting up a replacement secret. Values are encrypted by the API before
  // storage; legacy plaintext values are only tolerated for read compatibility.
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret  String? @map("two_factor_secret")
  // One-time recovery codes are stored as keyed HMACs, never plaintext.
  twoFactorBackupCodeHashes String[] @default([]) @map("two_factor_backup_code_hashes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  adminProfile               AdminUser?
  advertiser                 Advertiser?
  sessions                   Session[]
  devices                    Device[]
  settings                   UserSettings?
  payoutAccounts             PayoutAccount[]
  earnings                   EarningsLedger[]
  payoutRequests             PayoutRequest[]
  // Approvals this admin issued as a campaign reviewer (nullable FK on
  // CampaignApproval.reviewerId with ON DELETE SET NULL — see there).
  campaignApprovals          CampaignApproval[] @relation("CampaignReviewer")
  trustScore                 TrustScore?
  fraudFlags                 FraudFlag[]
  adReports                  AdReport[]
  waitStateEvents            WaitStateEvent[]
  adImpressions              AdImpression[]
  adClicks                   AdClick[]
  deviceRecoveryTokens       DeviceRecoveryToken[] @relation("DeviceRecoveryUserTokens")
  issuedDeviceRecoveryTokens DeviceRecoveryToken[] @relation("IssuedDeviceRecoveryTokens")
  recoveryDebtCases          RecoveryDebtCase[]    @relation("RecoveryDebtUserCases")
  openedRecoveryDebtCases    RecoveryDebtCase[]    @relation("RecoveryDebtOpenedBy")
  resolvedRecoveryDebtCases  RecoveryDebtCase[]    @relation("RecoveryDebtResolvedBy")
  referralOut                Referral[]            @relation("Referrer")
  referralIn                 Referral[]            @relation("Referred")
  referralRewards            ReferralReward[]
  apiKeys                    ApiKey[]
  consents                   Consent[]

  // The `email` @unique (above) already serves equality/like scans on
  // email; a separate @@index duplicates storage and write cost.
  @@index([role, status])
  @@unique([githubId])
  @@map("users")
}

model AdminUser {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminRole   UserRole
  permissions String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceHash  String?
  ipHash      String?
  tokenHash   String
  tokenFamily String?
  revoked     Boolean  @default(false)
  expiresAt   DateTime @db.Timestamptz

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([tokenFamily])
  // Session cleanup cron prunes rows by `expiresAt < cutoff` — without this
  // index the `deleteMany` is a seq scan that grows linearly with session
  // count, every hour, on every API replica.
  @@index([expiresAt])
  @@map("sessions")
}

model Device {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprintHash  String
  eventSecret      String? // per-device HMAC secret generated by server at registration
  publicKey        String?
  toolType         ToolTypeEnum
  extensionVersion String?
  platform         String?

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  waitStateEvents WaitStateEvent[]
  adImpressions   AdImpression[]
  adClicks        AdClick[]
  fraudFlags      FraudFlag[]
  recoveryTokens  DeviceRecoveryToken[]

  @@unique([userId, fingerprintHash])
  // Cross-user uniqueness — without this constraint two users could
  // register the same physical machine's fingerprint simultaneously, and
  // the JS-level duplicate check would race (TOCTOU). The DB-level
  // constraint enforces it atomically: P2002 is caught and treated as a
  // duplicate-detected fraud event.
  @@unique([fingerprintHash])
  @@index([userId])
  @@map("devices")
}

model DeviceRecoveryToken {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation("DeviceRecoveryUserTokens", fields: [userId], references: [id], onDelete: Cascade)
  deviceId        String
  device          Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User      @relation("IssuedDeviceRecoveryTokens", fields: [createdByUserId], references: [id], onDelete: Restrict)
  tokenHash       String    @unique
  reason          String?
  expiresAt       DateTime  @db.Timestamptz
  usedAt          DateTime? @db.Timestamptz
  revokedAt       DateTime? @db.Timestamptz

  createdAt DateTime @default(now())

  @@index([userId, deviceId, expiresAt])
  @@index([deviceId, usedAt, revokedAt, expiresAt])
  @@index([createdByUserId, createdAt])
  @@map("device_recovery_tokens")
}

// ══════════════════════════════════════════════════════════
// User Settings
// ══════════════════════════════════════════════════════════

model UserSettings {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  adsEnabled     Boolean @default(false)
  quietMode      Boolean @default(false)
  quietModeStart String  @default("22:00")
  quietModeEnd   String  @default("08:00")
  maxAdsPerHour  Int     @default(6)
  timezone       String?
  // A-057: per-developer persisted blocked category slugs. The API loads
  // these during ad selection and merges them with any per-request client-
  // supplied arrays, guaranteeing enforcement even when the client omits them.
  blockedCategories String[] @default([]) @map("blocked_categories")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// ══════════════════════════════════════════════════════════
// Payout Accounts
// ══════════════════════════════════════════════════════════

model PayoutAccount {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    PayoutProvider
  destination String
  currency    String         @default("USD")
  isVerified  Boolean        @default(false)
  isActive    Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payoutRequests PayoutRequest[]

  @@index([userId, provider, isActive])
  @@map("payout_accounts")
}

// ══════════════════════════════════════════════════════════
// Advertiser
// ══════════════════════════════════════════════════════════

model Advertiser {
  id               String     @id @default(uuid())
  userId           String     @unique
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName      String
  billingEmail     String
  // Globally unique per-Stripe-account. Without this, two advertisers could
  // be wired to the same Stripe customer via a TOCTOU race on the webhook
  // `advertiser.stripeCustomerId` first-time-set path.
  stripeCustomerId String?    @unique
  websiteUrl       String?
  trustStatus      TrustLevel @default(new)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns     Campaign[]
  ledgerEntries AdvertiserLedger[]
  apiKeys       ApiKey[]

  @@map("advertisers")
}

// ══════════════════════════════════════════════════════════
// Campaigns & Ads
// ══════════════════════════════════════════════════════════

model Campaign {
  id                  String         @id @default(uuid())
  advertiserId        String
  advertiser          Advertiser     @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  name                String
  status              CampaignStatus @default(draft)
  category            String
  bidType             BidType
  bidAmountMinor      BigInt
  budgetTotalMinor    BigInt
  budgetSpentMinor    BigInt         @default(0)
  currency            String         @default("USD")
  frequencyCapPerHour Int            @default(2)
  frequencyCapPerDay  Int            @default(6)
  qualityScore        Float          @default(0)
  submittedAt         DateTime?
  approvedAt          DateTime?
  activatedAt         DateTime?
  pausedAt            DateTime?
  archivedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatives        AdCreative[]
  impressions      AdImpression[]
  clicks           AdClick[]
  countryTargeting CountryTargeting[]
  approvals        CampaignApproval[]
  fraudFlags       FraudFlag[]
  earningsEntries  EarningsLedger[]
  advertiserLedger AdvertiserLedger[]
  platformLedger   PlatformLedger[]

  @@index([advertiserId])
  @@index([status])
  @@index([status, category])
  @@map("campaigns")
}

model AdCreative {
  id               String         @id @default(uuid())
  campaignId       String
  campaign         Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title            String
  sponsoredMessage String
  destinationUrl   String
  displayDomain    String
  ctaText          String?       @map("cta_text")
  status           CreativeStatus @default(draft)
  rejectionReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  impressions AdImpression[]
  clicks      AdClick[]
  adReports   AdReport[]

  @@index([campaignId])
  @@map("ad_creatives")
}

model Category {
  id           String  @id @default(uuid())
  slug         String  @unique
  name         String
  description  String?
  isBlocked    Boolean @default(false)
  isMvpAllowed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blockedEntries BlockedCategory[]

  @@map("categories")
}

model BlockedCategory {
  id         String    @id @default(uuid())
  categoryId String?
  // BlockedCategory rows are user-generated spam flags — when the underlying
  // Category row is removed by an admin, the blocks linger as a historical
  // reference (per record of "what was blocked when"), so SetNull lets the
  // audit row survive; the API layer filters out rows where category is null
  // for display purposes.
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  blockedBy  String
  reason     String

  createdAt DateTime @default(now())

  @@map("blocked_categories")
  @@index([categoryId])
}

model CountryTargeting {
  id          String   @id @default(uuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  countryCode String
  include     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, countryCode])
  @@index([campaignId])
  @@map("country_targeting")
}

model ToolIntegration {
  id         String       @id @default(uuid())
  slug       String       @unique
  name       String
  type       ToolTypeEnum
  minVersion String?
  isActive   Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tool_integrations")
}

// ══════════════════════════════════════════════════════════
// Events & Tracking
// ══════════════════════════════════════════════════════════

model WaitStateEvent {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId       String
  device         Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  sessionId      String
  eventType      EventType
  waitStateId    String
  toolType       ToolTypeEnum
  duration       Int?
  ipHash         String?
  signature      String
  idempotencyKey String       @unique

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([deviceId, createdAt])
  @@index([waitStateId, eventType])
  @@map("wait_state_events")
}

model AdImpression {
  id                  String     @id @default(uuid())
  campaignId          String
  // Impressions are the platform's permanent audit trail for an ad served.
  // Hard-deleting a Campaign row would cascade-delete every impression ever
  // served against it (millions of rows in production). RESTRICT prevents
  // silent cascades and forces a deliberate archival/retention decision
  // before deletion — same intent as the explicit AdClick/AdReport rules
  // documented below.
  campaign            Campaign   @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  creativeId          String
  creative            AdCreative @relation(fields: [creativeId], references: [id], onDelete: Restrict)
  userId              String
  // Soft-delete policy: the platform never hard-deletes User rows — the
  // deleteAccount path sets status='deleted' and anonymizes PII. The
  // Cascade here is the legacy schema's safety net for any future
  // hard-delete, but the policy above makes it deliberately unreachable.
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId            String
  device              Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  sessionId           String
  waitStateId         String?
  idempotencyKey      String?    @unique
  impressionTokenHash String     @unique
  renderedAt          DateTime?
  qualifiedAt         DateTime?  @db.Timestamptz
  visibleDurationMs   Int?
  visibleSurface      Float?
  isBillable          Boolean    @default(false)
  invalidationReason  String?
  invalidatedAt       DateTime?
  ipHash              String?

  createdAt DateTime @default(now())

  click      AdClick?
  earnings   EarningsLedger[]
  adReports  AdReport[]
  fraudFlags FraudFlag[]

  @@index([campaignId, qualifiedAt])
  @@index([userId, qualifiedAt])
  @@index([deviceId, qualifiedAt])
  @@index([ipHash, qualifiedAt])
  @@index([isBillable, createdAt])
  @@index([userId, sessionId])
  // FK back-reference scan: AdCreative.impressions 1:N — creativeId scan used
  // for creative-performance dashboard queries and re-render of same creative.
  @@index([creativeId])
  @@map("ad_impressions")
}

model AdClick {
  id                 String       @id @default(uuid())
  impressionId       String       @unique
  impression         AdImpression @relation(fields: [impressionId], references: [id], onDelete: Cascade)
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId           String
  device             Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  sessionId          String
  // Click-level billing evidence — must not cascade-delete when the parent
  // Campaign or AdCreative is removed (keep audit trail). RESTRICT is explicit
  // here; the prior schema had NO relation declared at all (also RESTRICT per
  // DB default), but no FK was ever created — here the FK is created as part
  // of the accompanying migration.
  campaignId         String
  campaign           Campaign     @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  creativeId         String
  creative           AdCreative   @relation(fields: [creativeId], references: [id], onDelete: Restrict)
  clickedAt          DateTime     @db.Timestamptz
  targetUrl          String
  isValid            Boolean      @default(true)
  invalidationReason String?
  idempotencyKey     String       @unique
  ipHash             String?

  createdAt DateTime @default(now())

  earnings   EarningsLedger[]
  fraudFlags FraudFlag[]

  @@index([userId, createdAt])
  @@index([isValid, createdAt])
  @@index([campaignId])
  @@index([creativeId])
  @@index([deviceId])
  @@map("ad_clicks")
}

model AdReport {
  id           String       @id @default(uuid())
  impressionId String
  impression   AdImpression @relation(fields: [impressionId], references: [id], onDelete: Cascade)
  creativeId   String
  // AdReports are user-generated complaints — keep audit trail intact when
  // the underlying creative is removed. RESTRICT prevents cascading a clean
  // delete of an abusive creative from overwriting the historical record
  // of what users reported against it.
  creative     AdCreative   @relation(fields: [creativeId], references: [id], onDelete: Restrict)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason       String
  details      String?
  resolution   String?
  resolvedAt   DateTime?    @db.Timestamptz
  resolvedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([impressionId])
  @@index([userId])
  @@index([creativeId])
  @@map("ad_reports")
}

// ══════════════════════════════════════════════════════════
// Ledger (append-only)
// ══════════════════════════════════════════════════════════

model EarningsLedger {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId     String?
  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  impressionId   String?
  impression     AdImpression?   @relation(fields: [impressionId], references: [id], onDelete: SetNull)
  clickId        String?
  click          AdClick?        @relation(fields: [clickId], references: [id], onDelete: SetNull)
  entryType      LedgerEntryType
  status         LedgerStatus
  amountMinor    BigInt
  currency       String          @default("USD")
  availableAt    DateTime?       @db.Timestamptz
  idempotencyKey String          @unique
  description    String?
  // Which fraud flag caused this entry to be `held`. NULL for entries held
  // by legacy callers (no flag) or for entries never held. Scopes the bulk
  // `releaseEarnings` so that releasing flag F1 cannot undo `held` entries
  // that belong to a still-open, unrelated flag F2 — the previous bulk
  // `WHERE userId AND status='held'` released every held entry across all
  // flags, letting a false-positive flag release money held by a genuine
  // concurrent fraud investigation (cross-flag money leak).
  heldByFlagId   String?
  heldByFlag     FraudFlag?      @relation(fields: [heldByFlagId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  payoutAllocations PayoutAllocation[]

  @@index([userId, status, availableAt])
  @@index([campaignId])
  @@index([createdAt])
  // Hot-path index for system-wide scans of fraud/review queues
  // (e.g. "all `estimated` ledger entries in the last hour"). Postgres
  // can use this for a leftmost-prefix where status IS the leading
  // column.
  @@index([status, createdAt])
  // Releasing a false-positive flag's holds scopes by heldByFlagId.
  @@index([heldByFlagId])
  @@index([impressionId])
  @@index([clickId])
  @@map("earnings_ledger")
}

model AdvertiserLedger {
  id                    String          @id @default(uuid())
  advertiserId          String
  advertiser            Advertiser      @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  campaignId            String?
  // FK to Campaign with `SetNull` — when a campaign is archived/deleted the
  // ledger row survives but its `campaignId` becomes NULL. The ledger is the
  // source of truth for historical accounting and must not be cascade-deleted
  // with its campaign; nulling the FK keeps referential integrity while
  // ensuring the row remains queryable by `advertiserId`/`createdAt`/etc.
  campaign              Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stripePaymentIntentId String?
  // The Stripe Dispute id when this row participates in a dispute freeze.
  // Set on the `hold`/`hold-rev` rows created by the dispute webhook and on
  // the parent deposit credit row while it's flipped to `held` status. NULL
  // for ordinary spend rows. Lets the dispute-close handler reliably locate
  // the rows to release or write off without re-scanning by amount/PI.
  stripeDisputeId       String?
  entryType             LedgerEntryType
  status                LedgerStatus
  amountMinor           BigInt
  currency              String          @default("USD")
  idempotencyKey        String          @unique
  description           String?

  createdAt DateTime @default(now())

  @@index([advertiserId, status])
  @@index([campaignId])
  @@index([createdAt])
  // Dispute lifecycle: the close handler locates held rows by dispute id.
  @@index([stripeDisputeId])
  @@map("advertiser_ledger")
}

model PlatformLedger {
  id             String          @id @default(uuid())
  campaignId     String?
  campaign       Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  entryType      LedgerEntryType
  status         LedgerStatus
  amountMinor    BigInt
  currency       String          @default("USD")
  bucket         String
  referenceId    String?
  idempotencyKey String          @unique
  description    String?

  createdAt DateTime @default(now())

  @@index([bucket, status])
  @@index([campaignId])
  @@index([createdAt])
  @@map("platform_ledger")
}

// ══════════════════════════════════════════════════════════
// Payouts
// ══════════════════════════════════════════════════════════

model PayoutRequest {
  id                   String        @id @default(uuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutAccountId      String
  payoutAccount        PayoutAccount @relation(fields: [payoutAccountId], references: [id], onDelete: Restrict)
  status               PayoutStatus  @default(draft)
  requestedAmountMinor BigInt
  approvedAmountMinor  BigInt?
  currency             String        @default("USD")
  reviewerId           String?
  reviewNote           String?
  processedAt          DateTime?
  paidAt               DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions PayoutTransaction[]
  allocations  PayoutAllocation[]

  @@index([userId])
  @@index([status])
  // Hot path: "my payouts in a given status" — dashboard list queries filter
  // by both user and status; the single-column indexes above force Postgres
  // to pick one and heap-filter the other.
  @@index([userId, status])
  @@index([payoutAccountId])
  @@map("payout_requests")
}

model PayoutAllocation {
  id              String         @id @default(uuid())
  payoutRequestId String
  payoutRequest   PayoutRequest  @relation(fields: [payoutRequestId], references: [id], onDelete: Cascade)
  earningsEntryId String
  earningsEntry   EarningsLedger @relation(fields: [earningsEntryId], references: [id], onDelete: Restrict)
  amountMinor     BigInt
  createdAt       DateTime       @default(now())

  @@unique([earningsEntryId])
  // FK back-reference scan: listing allocations for a specific payout
  // (payout detail screen, admin review) — without this index the FK
  // join on payoutRequestId does a seq scan.
  @@index([payoutRequestId])
  @@map("payout_allocations")
}

model PayoutTransaction {
  id              String         @id @default(uuid())
  payoutRequestId String
  payoutRequest   PayoutRequest  @relation(fields: [payoutRequestId], references: [id], onDelete: Cascade)
  provider        PayoutProvider
  providerTxId    String?
  status          PayoutStatus   @default(processing)
  paidAt          DateTime?
  failureReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Composite unique = idempotency floor: retried webhooks with the same
  // (provider, providerTxId) collide rather than double-creating rows.
  // NULL providerTxId values are distinct in Postgres, so in-flight rows
  // from `provider.initiate()` (which sets the txId immediately after)
  // coexist as expected.
  @@unique([provider, providerTxId])
  @@index([payoutRequestId])
  // Single-column index for txId-only lookups from provider callbacks.
  @@index([providerTxId])
  @@map("payout_transactions")
}

model RecoveryDebtCase {
  id                String                 @id @default(uuid())
  userId            String
  user              User                   @relation("RecoveryDebtUserCases", fields: [userId], references: [id], onDelete: Restrict)
  status            RecoveryDebtCaseStatus @default(open)
  amountMinor       BigInt
  currency          String                 @default("USD")
  externalReference String?
  note              String?
  openedByUserId    String?
  openedBy          User?                  @relation("RecoveryDebtOpenedBy", fields: [openedByUserId], references: [id], onDelete: SetNull)
  resolvedByUserId  String?
  resolvedBy        User?                  @relation("RecoveryDebtResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolvedAt        DateTime?              @db.Timestamptz

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, currency])
  @@index([status, updatedAt])
  @@index([openedByUserId, createdAt])
  @@index([resolvedByUserId, resolvedAt])
  @@map("recovery_debt_cases")
}

// ══════════════════════════════════════════════════════════
// Fraud & Trust
// ══════════════════════════════════════════════════════════

model FraudFlag {
  id           String          @id @default(uuid())
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  deviceId     String?
  device       Device?         @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  campaignId   String?
  campaign     Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  impressionId String?
  impression   AdImpression?   @relation(fields: [impressionId], references: [id], onDelete: SetNull)
  clickId      String?
  click        AdClick?        @relation(fields: [clickId], references: [id], onDelete: SetNull)
  // First-class idempotency key for Stripe dispute flags. Kept outside JSON
  // evidence so Prisma drift checks and the database can enforce uniqueness.
  stripeDisputeId String?       @unique
  flagType     FraudFlagType
  severity     FraudSeverity   @default(medium)
  status       FraudFlagStatus @default(open)
  scoreDelta   Int             @default(0)
  evidence     Json
  reviewNote   String?
  reviewerId   String?
  resolvedAt   DateTime?              @db.Timestamptz

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relation: ledger entries held under this flag (see EarningsLedger).
  heldEarnings EarningsLedger[]

  @@index([userId, status])
  @@index([deviceId, status])
  @@index([campaignId, status])
  @@index([flagType, severity])
  @@index([status, createdAt])
  @@index([impressionId])
  @@index([clickId])
  @@map("fraud_flags")
}

model TrustScore {
  id                 String     @id @default(uuid())
  userId             String     @unique
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  score              Int        @default(40)
  level              TrustLevel @default(new)
  accountAgePoints   Int        @default(0)
  emailVerifiedPts   Int        @default(0)
  githubVerifiedPts  Int        @default(0)
  googleVerifiedPts  Int        @default(0)
  deviceConsistPts   Int        @default(0)
  activityPatternPts Int        @default(0)
  payoutHistoryPts   Int        @default(0)
  fraudPenaltyPts    Int        @default(0)

  computedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("trust_scores")
}

// ══════════════════════════════════════════════════════════
// Campaign Approvals
// ══════════════════════════════════════════════════════════

model CampaignApproval {
  id         String           @id @default(uuid())
  campaignId String
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // Nullable + ON DELETE SET NULL: a historical approval record survives even
  // after the admin who reviewed it is deleted (reviewer becomes NULL instead
  // of cascading or refusing the user delete). FK is added by migration
  // 20260714000000; previously reviewerId had no FK so garbage UUIDs could
  // be inserted silently.
  reviewerId String?
  reviewer   User?            @relation("CampaignReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  decision   ApprovalDecision
  reason     String?
  checklist  Json?

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@map("campaign_approvals")
}

// ══════════════════════════════════════════════════════════
// API Keys & Webhooks
// ══════════════════════════════════════════════════════════

model ApiKey {
  id           String      @id @default(uuid())
  ownerId      String?
  owner        User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  advertiserId String?
  advertiser   Advertiser? @relation(fields: [advertiserId], references: [id], onDelete: SetNull)
  keyHash      String      @unique
  keyPrefix    String
  scopes       String[]
  isActive     Boolean     @default(true)
  lastUsedAt   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime? @db.Timestamptz

  @@index([ownerId])
  @@index([advertiserId])
  // The `keyHash` @unique (above) already serves equality lookups — a
  // separate @@index duplicates storage/write cost.
  @@map("api_keys")
}

model WebhookEvent {
  id               String    @id @default(uuid())
  provider         String
  // Uniqueness is scoped by [provider, eventId] — different providers
  // (stripe, paypal, …) maintain independent id namespaces, so a
  // provider-blind global unique constraint on `eventId` alone would
  // wrongly collide two legitimate events from different providers that
  // happen to share an id. The composite index is the authoritative
  // idempotency floor keyed on the (provider, eventId) pair.
  eventId          String
  eventType        String
  payload          Json
  processingStatus String    @default("pending")
  processedAt      DateTime?
  error            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([processingStatus])
  @@map("webhook_events")
}

// ══════════════════════════════════════════════════════════
// Audit Log
// ══════════════════════════════════════════════════════════

model AuditLog {
  id         String  @id @default(uuid())
  actorId    String
  actorRole  String
  targetType String
  targetId   String
  action     String
  beforeSnap Json?
  afterSnap  Json?
  ipHash     String?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@index([createdAt])
  // Hot-path composite indexes — audit reads are almost always time-bounded
  // (`WHERE actorId = ? AND createdAt > ?`, `WHERE targetType = ? AND …`).
  // The leading single/double columns above can't serve these without a
  // sort+filter on createdAt, so Postgres would heap-filter every matching row.
  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@map("audit_logs")
}

model CronLease {
  key       String   @id
  ownerId   String
  expiresAt DateTime @db.Timestamptz
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("cron_leases")
}

// ══════════════════════════════════════════════════════════
// Referrals
// ══════════════════════════════════════════════════════════

model Referral {
  id         String @id @default(uuid())
  // Referrer side: implicit RESTRICT by design. Referrals are the source of
  // truth for accrued referral rewards (ReferralReward.userId CASCADEs from
  // the referrer's own User row, but only if the referrer can be deleted —
  // RESTRICT here prevents hard-deleting a referrer while rewards reference
  // them, preserving the earning history). The referrer is never silently
  // cascade-deleted; an admin must clear their referrals first.
  referrerId String
  referrer   User   @relation("Referrer", fields: [referrerId], references: [id], onDelete: Restrict)
  // Referred side: CASCADE. A referral ceases to be meaningful once the
  // referred account is gone; cascade-deleting the referral row also
  // CASCADEs its ReferralReward rows (referral_rewards.referralId) cleanly.
  // Without this annotation the FK is implicit RESTRICT (matching 0_init),
  // which needlessly blocked User hard-delete when the only blocker was a
  // referral row — inconsistent with the Session/Device/... cascade policy.
  referredId String
  referred   User   @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  code       String @unique
  status     ReferralStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rewards ReferralReward[]

  // DB-level guard: a user can only be referred once. The service-layer
  // check-then-create is racy; this unique index closes that race.
  @@unique([referredId])
  @@index([referrerId])
  @@index([referredId])
  @@map("referrals")
}

model ReferralReward {
  id          String       @id @default(uuid())
  referralId  String
  referral    Referral     @relation(fields: [referralId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMinor BigInt
  currency    String       @default("USD")
  status      LedgerStatus @default(estimated)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // DB-level guard: at most one reward per referral. The service-layer check-then-create
  // in processReferralRewards is racy when markPayoutPaid is invoked concurrently or
  // retried by a webhook; a unique index here is the authoritative floor.
  // Note: @@unique([referralId]) already maintains a B-tree on referralId in Postgres,
  // so no separate @@index([referralId]) is needed — a duplicate index was removed in
  // migration 20260714000000 (it doubled write cost on every insert with no read benefit).
  @@unique([referralId])
  @@index([userId])
  @@map("referral_rewards")
}

// ══════════════════════════════════════════════════════════
// Consent & Data Retention
// ══════════════════════════════════════════════════════════

// Records explicit user consent (e.g. marketing cookies, privacy policy version,
// terms acceptance). Consent is append-only — withdrawing creates a new row with
// `granted = false` rather than mutating history, so the audit trail is intact.
model Consent {
  id          String   @id @default(uuid())
  // Nullable to support privacy-minimized ANONYMOUS (logged-out) consent where
  // no authenticated user exists. Authenticated consent always sets `userId`.
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // e.g. "privacy_policy", "marketing_cookies", "terms_of_service"
  purpose     String
  // Version of the policy/terms the consent applies to (e.g. "2026-07-01").
  version     String
  granted     Boolean  @default(true)
  // Optional free-text or structured context (method of capture).
  metadata    Json?
  // sha256 of a client-generated pseudonymous visitor id for anonymous,
  // logged-out consent. Never stores the raw id, IP, or other PII (A-009).
  visitorIdHash String?

  createdAt DateTime @default(now())

  @@index([userId, purpose])
  @@index([purpose, version])
  @@index([visitorIdHash])
  @@map("consents")
}

// Operator-tunable retention windows (in days) per data category. A single row
// (keyed by `category`) drives the retention cron so thresholds are config, not
// code. Categories: "webhook_events", "audit_logs", "sessions", "export_cache".
model DataRetentionConfig {
  id        String @id @default(uuid())
  category  String @unique
  // Number of days to retain before the retention cron purges. NULL = retain
  // indefinitely (never purge this category).
  retainDays Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("data_retention_config")
}

// ══════════════════════════════════════════════════════════
// Email Queue
// ══════════════════════════════════════════════════════════

// Persisted queue for transactional emails that failed immediate delivery.
// Retried by EmailQueueCron with exponential backoff until success, permanent
// failure, or the row expires. The content-hash unique constraint coalesces
// duplicate messages so a burst of identical failures does not multiply
// queue depth.
model EmailQueue {
  id          String   @id @default(uuid())
  to          String
  subject     String
  html        String
  text        String?
  contentHash String   @unique @map("content_hash")
  retryCount  Int      @default(0) @map("retry_count")
  nextRetryAt DateTime @db.Timestamptz @map("next_retry_at")
  expiresAt   DateTime @db.Timestamptz @map("expires_at")
  lastError   String?  @map("last_error")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([nextRetryAt])
  @@index([expiresAt])
  @@map("email_queue")
}
