    "db:seed": "tsx prisma/seed.ts",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.0",
    "@waitlayer/eslint-config": "workspace:*",
    "prisma": "^7.8.0",
    "typescript": "^5.9.2"
  }
