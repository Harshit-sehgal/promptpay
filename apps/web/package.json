{
  "name": "waitlayer-web",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "node scripts/verify-deploy-env.mjs",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.67.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@waitlayer/shared": "workspace:*",
    "@waitlayer/ui": "workspace:*",
    "axios": "^1.18.1",
    "jose": "^6.2.4",
    "lucide-react": "^1.24.0",
    "next": "^16.2.11",
    "qrcode": "^1.5.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@next/eslint-plugin-next": "^16.2.11",
    "@playwright/test": "^1.51.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@waitlayer/eslint-config": "workspace:*",
    "autoprefixer": "^10.5.4",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.22",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
