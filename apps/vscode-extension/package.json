{
  "name": "waitlayer-vscode",
  "displayName": "WaitLayer",
  "version": "0.0.1",
  "publisher": "waitlayer",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harshit-sehgal/promptpay.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:waitlayer.login",
    "onCommand:waitlayer.logout",
    "onCommand:waitlayer.showEarnings",
    "onCommand:waitlayer.toggleAds",
    "onCommand:waitlayer.openDashboard",
    "onCommand:waitlayer.reportFalseWait",
    "onCommand:waitlayer.showExperimentAssignment",
    "onCommand:waitlayer.toggleDetectorSource"
  ],
  "contributes": {
    "commands": [
      {
        "command": "waitlayer.login",
        "title": "WaitLayer: Login"
      },
      {
        "command": "waitlayer.logout",
        "title": "WaitLayer: Logout"
      },
      {
        "command": "waitlayer.showEarnings",
        "title": "WaitLayer: Show Earnings"
      },
      {
        "command": "waitlayer.toggleAds",
        "title": "WaitLayer: Toggle Ads"
      },
      {
        "command": "waitlayer.openDashboard",
        "title": "WaitLayer: Open Dashboard"
      },
      {
        "command": "waitlayer.reportFalseWait",
        "title": "WaitLayer: Report false wait detection"
      },
      {
        "command": "waitlayer.showExperimentAssignment",
        "title": "WaitLayer: Show detector experiment assignment"
      },
      {
        "command": "waitlayer.toggleDetectorSource",
        "title": "WaitLayer: Toggle detector source"
      }
    ],
    "configuration": {
      "title": "WaitLayer",
      "properties": {
        "waitlayer.adsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ads during AI wait states"
        },
        "waitlayer.maxAdsPerHour": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 30,
          "description": "Maximum ads shown per hour"
        },
        "waitlayer.inactivityTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 3000,
          "maximum": 120000,
          "description": "Milliseconds of inactivity before detecting a wait state"
        },
        "waitlayer.quietMode.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable quiet hours — no ads shown during specified times"
        },
        "waitlayer.quietMode.start": {
          "type": "string",
          "default": "22:00",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "description": "Quiet hours start time (HH:MM, 24h)"
        },
        "waitlayer.quietMode.end": {
          "type": "string",
          "default": "08:00",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "description": "Quiet hours end time (HH:MM, 24h)"
        },
        "waitlayer.apiUrl": {
          "type": "string",
          "default": "https://api.waitlayer.com/api/v1",
          "description": "WaitLayer API base URL"
        },
        "waitlayer.preferredDisplayCurrency": {
          "type": "string",
          "default": "",
          "description": "Preferred display currency for earnings (e.g. USD, EUR, JPY). Empty uses the derived primary currency. Only used when present in your balance; otherwise the primary currency is shown with a note."
        },
        "waitlayer.detectorRolloutPercent": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 100,
          "description": "Staged rollout percentage (0-100) for detector experiments. Default 100 enrolls everyone."
        },
        "waitlayer.disabledDetectorSources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Detector signal sources to disable (e.g. inactivity, terminal, task, editor_idle)."
        },
        "waitlayer.falsePositiveSuppressionMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "maximum": 10080,
          "description": "How long (minutes) new waits/ads are suppressed after reporting a false positive."
        }
      }
    },
    "keybindings": [
      {
        "command": "waitlayer.reportFalseWait",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run bundle",
    "bundle": "pnpm --filter @waitlayer/shared build && node ./scripts/build.mjs && node ./scripts/verify-bundle.cjs",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "eslint src/ test/",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run bundle",
    "test": "vitest run",
    "package:vsix": "vsce package --no-dependencies",
    "publish:vsix": "vsce publish --no-dependencies"
  },
  "main": "./out/extension.js",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "@waitlayer/eslint-config": "workspace:*",
    "@waitlayer/shared": "workspace:*",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
