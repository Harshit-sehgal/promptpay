{
  "name": "waitlayer-vscode",
  "displayName": "WaitLayer",
  "version": "0.0.1",
  "publisher": "waitlayer",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:waitlayer.login",
    "onCommand:waitlayer.logout",
    "onCommand:waitlayer.showEarnings",
    "onCommand:waitlayer.toggleAds",
    "onCommand:waitlayer.openDashboard"
  ],
  "contributes": {
    "commands": [
      {
        "command": "waitlayer.login",
        "title": "WaitLayer: Login"
      },
      {
        "command": "waitlayer.logout",
        "title": "WaitLayer: Logout"
      },
      {
        "command": "waitlayer.showEarnings",
        "title": "WaitLayer: Show Earnings"
      },
      {
        "command": "waitlayer.toggleAds",
        "title": "WaitLayer: Toggle Ads"
      },
      {
        "command": "waitlayer.openDashboard",
        "title": "WaitLayer: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "WaitLayer",
      "properties": {
        "waitlayer.adsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable ads during AI wait states"
        },
        "waitlayer.maxAdsPerHour": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 30,
          "description": "Maximum ads shown per hour"
        },
        "waitlayer.inactivityTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 3000,
          "maximum": 120000,
          "description": "Milliseconds of inactivity before detecting a wait state"
        },
        "waitlayer.quietMode.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable quiet hours — no ads shown during specified times"
        },
        "waitlayer.quietMode.start": {
          "type": "string",
          "default": "22:00",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "description": "Quiet hours start time (HH:MM, 24h)"
        },
        "waitlayer.quietMode.end": {
          "type": "string",
          "default": "08:00",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "description": "Quiet hours end time (HH:MM, 24h)"
        },
        "waitlayer.apiUrl": {
          "type": "string",
          "default": "https://api.waitlayer.com/api/v1",
          "description": "WaitLayer API base URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "eslint src/ test/",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run compile",
    "test": "vitest run",
    "package:vsix": "vsce package --no-dependencies",
    "publish:vsix": "vsce publish --no-dependencies"
  },
  "main": "./out/extension.js",
  "dependencies": {
    "@waitlayer/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.90.0",
    "@waitlayer/eslint-config": "workspace:*",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
