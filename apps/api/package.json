{
  "name": "waitlayer-api",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "nest start --watch --entryFile apps/api/src/main",
    "build": "nest build",
    "start": "nest start --entryFile apps/api/src/main",
    "start:prod": "node dist/apps/api/src/main",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run --pool=forks --no-file-parallelism --maxWorkers=1 --maxConcurrency=1 --exclude 'src/integration/**/*.spec.ts'",
    "test:integration": "for spec in src/integration/*.spec.ts; do DATABASE_URL=\"${TEST_DATABASE_URL:-postgresql://waitlayer:waitlayer-test@localhost:5433/waitlayer_test?schema=public}\" pnpm --filter @waitlayer/db exec prisma migrate reset --force && pnpm exec vitest run \"$spec\" --pool=forks --no-file-parallelism --maxWorkers=1 --maxConcurrency=1 || exit $?; done",
    "test:watch": "vitest",
    "test:cov": "vitest run --pool=forks --no-file-parallelism --maxWorkers=1 --maxConcurrency=1 --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@sentry/nestjs": "^10.67.0",
    "@sentry/profiling-node": "^10.67.0",
    "@types/cookie-parser": "^1.4.10",
    "@waitlayer/config": "workspace:*",
    "@waitlayer/db": "workspace:*",
    "@waitlayer/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.0.0",
    "helmet": "^8.3.0",
    "lru-cache": "^11.5.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/ms": "2.1.0",
    "@types/node": "^26.1.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@waitlayer/eslint-config": "workspace:*",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
