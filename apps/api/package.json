  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@waitlayer/eslint-config": "workspace:*",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
