{
  "name": "waitlayer-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch --entryFile apps/api/src/main",
    "build": "nest build",
    "start": "nest start --entryFile apps/api/src/main",
    "start:prod": "node dist/apps/api/src/main",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/throttler": "^6.5.0",
    "@paypal/payouts-sdk": "^1.1.1",
    "@waitlayer/db": "workspace:*",
    "@waitlayer/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "express": "^5.0.0",
    "passport": "^0.7.0",
    "passport-google-id-token": "^0.4.7",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.3.0"
